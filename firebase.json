  {
  "functions": [
  {
    "source": "functions",
    "codebase": "default",
    "ignore": [
      "node_modules",
      ".git",
      "firebase-debug.log",
      "firebase-debug.*.log",
      "*.local"
    ],
    "predeploy": [
      "npm --prefix \"$RESOURCE_DIR\" run lint",
      "npm --prefix \"$RESOURCE_DIR\" run build"
    ]
  }
  ],
  "firestore": {
  "rules": "firestore.rules"
  },
  "hosting": {
  "public": "public",
  "ignore": [
  "firebase.json",
  "**/.*",
  "**/node_modules/**"
  ],
  "headers": [
  {
    "source": "/__/auth/**",
    "headers": [
      {
        "key": "Cross-Origin-Opener-Policy",
        "value": "same-origin-allow-popups"
      }
    ]
  },
  {
    "source": "**",
    "headers": [
      {
        "key": "Cross-Origin-Opener-Policy",
        "value": "same-origin"
      }
    ]
  }
  ]
  },
  "storage": {
  "rules": "storage.rules"
  }
  }
